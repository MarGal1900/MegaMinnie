# Server
HOST=127.0.0.1
PORT=3000

# Preview-modus: true = geen upload naar Salesforce (standaond, veilig voor ontwikkeling)
# Zet op false pas als SF-credentials kloppen en je live wilt syncen
MEGAMINNIE_DRY_RUN=true

# Testmodus (server-default): true = testomgeving, bibliotheek met opnames
# Productie: zet op false — invoer (opname) wordt na verwerking gewist; bibliotheek alleen via UI prullenbak
MEGAMINNIE_KEEP_INPUT=true

# Optioneel: beveilig API-endpoints (header X-API-Key in requests)
# MEGAMINNIE_API_KEY=

# Max. upload-requests per minuut per IP (standaard 30)
# MEGAMINNIE_RATE_LIMIT=30
# Transcriptie (interview stemcommando's): aparte limiet (standaard 180)
# MEGAMINNIE_TRANSCRIBE_RATE_LIMIT=180

# LLM: Claude (bedrijfsaccount Anthropic) — aanbevolen voor foto & uitwerking
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Model uit je Claude/Anthropic-console (bijv. claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Optioneel apart model voor foto's (standaard = ANTHROPIC_MODEL)
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514

# --- Spraak / Whisper (één van beide opties) ---

# Optie A: OpenAI transcriptie in de cloud (standaard: gpt-4o-mini-transcribe)
# OPENAI_API_KEY=
# WHISPER_PROFILE=quality
#   quality = gpt-4o-mini-transcribe (standaard; ook live bij Realtime Q&A)
#   fast    = gpt-4o-mini-transcribe
#   diarize = gpt-4o-transcribe-diarize (klant + accountmanager)
#   legacy  = whisper-1
# WHISPER_LANGUAGE=nl
# WHISPER_MODEL=gpt-4o-mini-transcribe

# Optie B: Lokaal faster-whisper via Speaches (aanbevolen met Claude)
#   npm run whisper:up   (eerste start duurt enkele minuten)
#   npm run whisper:download  (optioneel, model vooraf downloaden)
# WHISPER_BASE_URL=http://127.0.0.1:8000/v1
# WHISPER_API_KEY=local
# WHISPER_LOCAL_MODEL=Systran/faster-whisper-medium
# WHISPER_LOCAL_MODEL=Systran/faster-whisper-large-v3

# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Alleen bij LLM_PROVIDER=openai (alle verwerking via OpenAI)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_IMAGE_DETAIL=high

# Realtime interview (beta, OpenAI Realtime via WebRTC)
REALTIME_INTERVIEW_ENABLED=true
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=verse
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# OPENAI_REALTIME_INSTRUCTIONS=
# Voorlezen (zelfde stem als realtime): OpenAI Speech API
# OPENAI_SPEECH_MODEL=gpt-4o-mini-tts

IMAGE_MAX_EDGE=2048
IMAGE_JPEG_QUALITY=90
# quality = transcriptie + MegaMinnie; fast = één API-call (alleen OpenAI-pfad)
PHOTO_PIPELINE=quality

# Salesforce (Connected App + integratiegebruiker)
# Uitgebreide setup: docs/SALESFORCE.md  |  Test: npm run sf:check
SF_LOGIN_URL=https://login.salesforce.com
# Sandbox: https://test.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=

# Optioneel: standaard record voor notities (Account/Contact/Opportunity Id)
# Bij verwerking kan automatisch gesynchroniseerd worden (niet alleen via sync-knop)
SF_DEFAULT_WHAT_ID=

# Standaard e-mailhandtekening bij "Email verzenden" (regels met \n)
# MEGAMINNIE_MAIL_SIGNATURE=Marc van Galen\nCCS\nmarc@example.com | T 06-12345678

# Standaard verantwoordelijke op taken (later koppelen aan SF-gebruiker/rol via ownerId)
# MEGAMINNIE_DEFAULT_ACCOUNT_MANAGER=Accountmanager
